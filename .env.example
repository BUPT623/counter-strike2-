# Copy values into your local .env or set them in Windows environment variables.
# Do not commit real push credentials.

# Global switch. config/automation_config.json also has notifications.enabled.
CS_APP_NOTIFY_ENABLED=0
CS_APP_EXPORT_EXCEL=0

# Choose one: bark, ntfy, serverchan
CS_APP_PUSH_PROVIDER=serverchan

# Bark iOS
CS_APP_BARK_KEY=
CS_APP_BARK_BASE_URL=https://api.day.app

# ntfy iOS
CS_APP_NTFY_TOPIC=
CS_APP_NTFY_SERVER=https://ntfy.sh
CS_APP_NTFY_TOKEN=

# ServerChan
CS_APP_SERVERCHAN_SENDKEY=
CS_APP_SERVERCHAN_BASE_URL=https://sctapi.ftqq.com
